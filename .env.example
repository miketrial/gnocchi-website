# Copy to .env for local `netlify dev`. NEVER commit .env.
# Also set these in Netlify: Site configuration → Environment variables (scoped to Functions).
# Do NOT prefix with NEXT_PUBLIC_ / VITE_ — that would leak them into the browser bundle.

FMP_API_KEY=
ANTHROPIC_API_KEY=

# Netlify Blobs needs no key when deployed (auto-scoped). For local `netlify dev`
# it is also automatic once you're linked (`netlify link`).
